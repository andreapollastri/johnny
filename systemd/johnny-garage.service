[Unit]
Description=Johnny object storage (Garage S3-compatible)
Documentation=https://garagehq.deuxfleurs.fr/documentation/quick-start/
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=johnny
Group=johnny
ConfigurationDirectory=johnny
StateDirectory=johnny
ExecStart=/usr/local/bin/garage -c /etc/johnny/garage.toml server
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
