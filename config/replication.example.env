# Example variables for cron wrappers on the primary VPS (VPS1) only.
# Do not commit real secrets; use mode 600 and paths outside the repo in production.

export RCLONE_CONFIG=/etc/johnny/rclone-replica.conf

export RCLONE_SRC_REMOTE=johnny-main
export RCLONE_SRC_BUCKET=app-data

