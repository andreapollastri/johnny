# TLS certificates: use certbot or your CA. Replace server_name and paths.
# Include from sites-enabled; Garage S3 API listens on 127.0.0.1:3900 (see garage.toml).

upstream johnny_s3 {
    server 127.0.0.1:3900;
    keepalive 32;
}

server {
    listen 443 ssl http2;
    server_name main.johnny.it;

    ssl_certificate     /etc/letsencrypt/live/main.johnny.it/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/main.johnny.it/privkey.pem;

    # Large multipart uploads
    client_max_body_size 0;

    location / {
        proxy_pass http://johnny_s3;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_request_buffering off;
        proxy_buffering off;
    }
}
