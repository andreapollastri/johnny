# Example Garage config for Johnny. Copy to /etc/johnny/garage.toml and replace secrets.
# Generate rpc_secret (hex 32 bytes), admin_token, metrics_token with openssl (see README).

metadata_dir = "/var/lib/johnny/meta"
data_dir = "/var/lib/johnny/data"
db_engine = "sqlite"

replication_factor = 1

# RPC: use private network addresses in multi-node clusters; localhost is fine for a single VPS
rpc_bind_addr = "[::]:3901"
rpc_public_addr = "127.0.0.1:3901"
rpc_secret = "REPLACE_WITH_openssl_rand_hex_32"

[s3_api]
s3_region = "johnny"
api_bind_addr = "127.0.0.1:3900"
# Virtual-hosted-style bucket URLs; align with your public S3 hostname
root_domain = ".s3.main.johnny.it"

[s3_web]
bind_addr = "127.0.0.1:3902"
root_domain = ".web.main.johnny.it"
index = "index.html"

[k2v_api]
api_bind_addr = "127.0.0.1:3904"

[admin]
api_bind_addr = "127.0.0.1:3903"
admin_token = "REPLACE_WITH_openssl_rand_base64_32"
metrics_token = "REPLACE_WITH_openssl_rand_base64_32"
