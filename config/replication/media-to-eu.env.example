# Example env for scripts/replicate-run.sh (VPS1 only).
# Copy to /etc/johnny/replication/<name>.env with mode 600.

export RCLONE_CONFIG=/etc/johnny/rclone-replica.conf
export RCLONE_SRC_REMOTE=johnny-main
export RCLONE_SRC_BUCKET=media
export RCLONE_DST_REMOTE=johnny-eu
export RCLONE_DST_BUCKET=media-replica-eu
